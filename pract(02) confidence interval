#ci for mean
x<-c(1,33,5,7,8)
y<-c(21,22,23,24,25)
t.test(x,conf.level = 0.95)

#ci for population propotion
prop.test(45,100,conf.level=0.95)

#ci for paired sample
before<-c(21,24,25,26,27)
after<-c(25,26,27,28,29)
t.test(before,after,paired = TRUE,conf.level = 0.95)

#ci for variance
library(EnvStats)
varTest(x,conf.level = 0.95)

#ci for reg
model<-lm(y~x)
confint(model,level=0.95)
